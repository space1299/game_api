API_ACCESS_KEY=change-this
API_ACCESS_HEADER=X-API-Key

DB_URL=mongodb://username:password@host:27017

APP_ENV=dev
SERVE_STATIC=true
CORS_ORIGINS=http://localhost:8000,http://localhost:5173
STATS_CACHE_TTL=20

REPORT_N_TARGET=50
REPORT_N_MIN=30
REPORT_MAX_VERSIONS_BACK=2
REPORT_WINDOW_RULE_VERSION=v1
REPORT_SEASON_CAP=current_season_only

LOG_FILE=./log/api.log
